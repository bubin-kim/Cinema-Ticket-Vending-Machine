import tkinter as tk


movies = ["인사이드아웃", "서울의봄", "토이스토리", "원더랜드"]
price = 12000  # 모든 영화티켓 가격 동일

def book_ticket():
    if entry_movie.get().isdigit() and entry_ticket.get().isdigit():  # 숫자인지 확인
        movie_index = int(entry_movie.get()) - 1  # 사용자 입력을 리스트 인덱스로 변환
        tickets = int(entry_ticket.get())
        if 0 <= movie_index < len(movies):  # 번호가 영화목록 내 있는지 확인
            total = price * tickets
            result_label.config(text=f"{movies[movie_index]} 영화 {tickets}장 예매 완료!\n총 결제금액: {total}원")
        else:
            result_label.config(text="잘못된 영화 번호입니다!")
    else:
        result_label.config(text="숫자를 올바르게 입력해주세요!")  # 이미 만들어둔 Label의 텍스트를 변경해 출력

        
window = tk.Tk()
window.title("영화관 티켓 자판기")
window.geometry("350x350")  # 프로그램 창의 기본 크기를 (가로 350px, 세로 350px)으로 지정

# 안내문구
label_info = tk.Label(window, text="상영 중인 영화 목록:\n1. 인사이드아웃\n2. 서울의봄\n3. 토이스토리\n4. 원더랜드")
label_info.pack(pady=10)

# 영화 번호 입력
label_movie = tk.Label(window, text="예매할 영화 번호 입력:")
label_movie.pack()
entry_movie = tk.Entry(window)
entry_movie.pack()

# 티켓 수 입력
label_ticket = tk.Label(window, text="예매할 티켓 수 입력:")
label_ticket.pack()
entry_ticket = tk.Entry(window)
entry_ticket.pack()

# 예매 버튼
button_book = tk.Button(window, text="예매하기", command=book_ticket)
button_book.pack(pady=10)

# 결과 출력
result_label = tk.Label(window, text="")
result_label.pack(pady=10)

window.mainloop()
